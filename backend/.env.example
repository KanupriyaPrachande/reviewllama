# --- App ---
APP_ENV=development
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://reviewllama:reviewllama@localhost:5432/reviewllama

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- GitHub integration ---
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_USERNAME=reviewllama-bot

# --- Slack integration ---
SLACK_BOT_TOKEN=
