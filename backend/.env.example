# --- Model ---
MODEL_NAME=codellama/CodeLlama-7b-hf
MODEL_ADAPTER_PATH=./ml/training/output/lora-adapter
DEVICE=cuda
MAX_DIFF_TOKENS=2048

# --- Thresholds ---
SEVERITY_CONFIDENCE_THRESHOLD=0.6
